// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

//---------------ueer model---------------
enum Role {
  SUPER_ADMIN
  AGENT
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(AGENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//---------------user model end---------------

model Survey {
  // Section 1
  id              String    @id @default(uuid())
  userId          String
  district        String?
  village         String?
  latitude        Float?
  longitude       Float?
  elevation       Float?
  surveyNo        String?
  interviewDate   DateTime?
  interviewerName String?
  dataEntryClerk  String?

  // Section 2
  householdType      HouseholdType?
  ethnicity          String?
  // 2.2 responding member
  maleRespondentName String?
  maleRespondentCode String?
  maleRelationToHOH  Int?

  femaleRespondentName String?
  femaleRespondentCode String?
  femaleRelationToHOH  Int?

  // SECTION 3 - LAND
  landUnit        String?
  totalLandAccess Float?
  ownedLand       Float?
  rentedLand      Float?
  communalLand    Float?

  rainfedLand   Float?
  irrigatedLand Float?
  homeGarden    Float?
  grassland     Float?
  fallowLand    Float?
  forestLand    Float?
  pond          Float?
  rentedOutLand Float?

  numberOfParcels        Int?
  distanceBetweenParcels Float?

  // SECTION 4 - LIVESTOCK
  topIncomeSource1 String?
  topIncomeSource2 String?
  topIncomeSource3 String?
  topIncomeSource4 String?
  topIncomeSource5 String?

  crop1Importance String?
  crop2Importance String?
  crop3Importance String?

  // SECTION 4 - ASSETS
  roofMaterial        String?
  hasThermos          Boolean?
  floorMaterial       String?
  wallMaterial        String?
  cookingEnergy       String?
  hasRefrigerator     Boolean?
  drinkingWaterSource String?
  hasPhone            String?
  hasStove            Boolean?
  toiletType          String?
  hasTV               String?
  hasStoneMill        Boolean?
  hasAlmirah          Boolean?
  hasIron             Boolean?
  hasRadio            Boolean?
  hasSewingMachine    Boolean?
  hasVehicle          String?
  hasMotorbike        Boolean?

  ownedAssets    String?
  irrigationType String?
  hiresLabor     Boolean?

  //SECTION 5
  communityParticipation    Boolean?
  hasLeadershipRole         Boolean?
  processingCrop1           Boolean?
  processingCrop1Activities String?
  processingCrop2           Boolean?
  processingCrop2Activities String?
  processingCrop3           Boolean?
  processingCrop3Activities String?
  hasCreditAccess           Boolean?
  leisureTimeRating         String?

  // SECTION 6
  lessPreferredFoodDays Int?
  borrowFoodDays        Int?
  limitPortionDays      Int?
  limitAdultFoodDays    Int?
  reduceMealsDays       Int?

  foodInsufficiencyMonths Json?
  foodAidMonths           Json?

  cerealsDays       Int?
  tubersDays        Int?
  pulsesDays        Int?
  vitaminAVegDays   Int?
  leafyVegDays      Int?
  otherVegDays      Int?
  vitaminAFruitDays Int?
  otherFruitDays    Int?
  meatDays          Int?
  organMeatDays     Int?
  fishDays          Int?
  dairyDays         Int?
  eggDays           Int?
  oilDays           Int?
  sugarDays         Int?
  spicesDays        Int?

  crop1ConsumptionPattern Json?
  crop2ConsumptionPattern Json?
  crop3ConsumptionPattern Json?

  // SECTION 7
  introducedCrop      Boolean?
  testingCrop         Boolean?
  stoppedCrop         Boolean?
  stoppedCropOnSeason Boolean?
  expandedCrop        Boolean?
  reducedCrop         Boolean?

  //Reasons for new crop
  stopUsingCropVariety Boolean?
  newVariety           Boolean?
  isHighYielding       Boolean?
  isBetterQuality      Boolean?
  isPreTreatedSeed     Boolean?
  isShorterCycle       Boolean?
  isLongerCycle        Boolean?
  isDroughtTolerant    Boolean?
  isFloodTolerant      Boolean?
  isSalinityTolerant   Boolean?
  isToxicityTolerant   Boolean?
  isDiseaseResistant   Boolean?
  isPestResistant      Boolean?

  earlyPreparation         Boolean?
  latePlanting             Boolean?
  intercropping            Boolean?
  changeInFarmingTimeOther String?

  introducedIntercropping      Boolean?
  introducedCropCover          Boolean?
  introducedMulching           Boolean?
  introducedRotations          Boolean?
  introducedHedges             Boolean?
  builtRidgesOrBunds           Boolean?
  introducedTerraces           Boolean?
  introducedStoneTerraces      Boolean?
  introducedContourPloughing   Boolean?
  improvedIrrigationEfficiency Boolean?
  improvedDrainage             Boolean?
  introducedMicroCatchments    Boolean?
  tidalWaterControl            Boolean?
  startedIrrigating            Boolean?
  stoppedIrrigating            Boolean?

  mechanizedFarming           Boolean?
  increasedChemicalFertilizer Boolean?
  startedManureCompost        Boolean?
  stoppedManureCompost        Boolean?
  increasedPesticideUse       Boolean?
  integratedPestManagement    Boolean?
  integratedCropManagement    Boolean?

  introducedNewAnimals   Boolean?
  testingNewAnimals      Boolean?
  stoppedKeepingAnimals  Boolean?
  introducedNewBreed     Boolean?
  reducedHerdSize        Boolean?
  increasedHerdSize      Boolean?
  changedHerdComposition Boolean?
  stallKeeping           Boolean?
  fencing                Boolean?
  cutAndCarry            Boolean?
  growingFodderCrops     Boolean?
  improvedPastures       Boolean?
  fodderStorage          Boolean?
  otherLivestockChanges  String? // "Other"

  // Info received
  manReceivedClimateInfo   Boolean?
  womanReceivedClimateInfo Boolean?

  // Source of info
  manInfoSource   String?
  womanInfoSource String?

  // Open-ended answer
  adaptationChangesLast3Years String?

  roleInProduction RoleInProduction[]

  members                 HouseholdMember[]
  crops                   Crop[]
  cropProductions         CropProduction[]
  processedProducts       ProcessedProduct[]
  livestocks              Livestock[]
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt
  livestockIncomeFromOwn  IncomeFromLiveStock[]
  livestockActivityOnFarm LivestockImportantOnFarm[]
  offFarmIncome           OffFarmIncome[]
}

//////////////////////
// HOUSEHOLD MEMBERS
//////////////////////

enum HouseholdType {
  MW
  MH
  WH
  MA
  FD
  CH
  OH
}

model HouseholdMember {
  id             String  @id @default(uuid())
  surveyId       String
  memberCode     String
  name           String?
  gender         String
  age            Int?
  yearOfBirth    Int?
  educationYears Int?
  isEnrolled     Boolean
  isIncomeEarner Boolean
  farmMonths     Int?

  response Survey @relation(fields: [surveyId], references: [id])
}

//////////////////////
// CROPS
//////////////////////

model Crop {
  id       String @id @default(uuid())
  surveyId String

  cropName          String
  areaPlanted       Float?
  isConsumed        Boolean
  isIncomeGenerated Boolean
  inputsUsed        String?

  response Survey @relation(fields: [surveyId], references: [id])
}

//////////////////////
// PROCESSED PRODUCTS
//////////////////////

model ProcessedProduct {
  id       String @id @default(uuid())
  surveyId String

  crop    String
  product String

  response Survey @relation(fields: [surveyId], references: [id])
}

//////////////////////
// CROP PRODUCTION
//////////////////////

model CropProduction {
  id       String @id @default(uuid())
  surveyId String

  cropName      String
  cropVarieties CropVariety[]

  response Survey @relation(fields: [surveyId], references: [id])
}

model CropVariety {
  id               String  @id @default(uuid())
  cropProductionId String
  variety          String
  areaSown         Float?
  yieldKg          Float?
  seedSource       String?
  product          String?
  salePercentage   Float?
  buyer            String?
  pricePerKg       Float?

  cropProduction CropProduction @relation(fields: [cropProductionId], references: [id], onDelete: Cascade)
}

//////////////////////
// LIVESTOCK
//////////////////////

model Livestock {
  id       String @id @default(uuid())
  surveyId String

  animalType        String
  quantity          Float?
  isIncomeGenerated Boolean

  response Survey @relation(fields: [surveyId], references: [id])
}

model IncomeFromLiveStock {
  id       String @id @default(uuid())
  surveyId String

  source         String
  isIncomeEarned Boolean @default(false)

  response Survey @relation(fields: [surveyId], references: [id])
}

model LivestockImportantOnFarm {
  id       String @id @default(uuid())
  surveyId String

  source         String
  isIncomeEarned Boolean @default(false)

  response Survey @relation(fields: [surveyId], references: [id])
}

model OffFarmIncome {
  id       String @id @default(uuid())
  surveyId String

  source         String
  isIncomeEarned Boolean @default(false)

  response Survey @relation(fields: [surveyId], references: [id])
}

//section 5
model RoleInProduction {
  id       String @id @default(uuid())
  surveyId String

  recivedCashFromCrop      String?
  recivedCashFromLiveStock String?
  howDeciedCropCash        String?
  howDeciedLiveStockCash   String?

  activityTrack ActivtiyTrack[]

  response Survey @relation(fields: [surveyId], references: [id])
}

model ActivtiyTrack {
  id                 String @id @default(uuid())
  roleInProductionId String

  activity        String
  performanceWork String
  task            String

  role RoleInProduction @relation(fields: [roleInProductionId], references: [id], onDelete: Cascade)
}
